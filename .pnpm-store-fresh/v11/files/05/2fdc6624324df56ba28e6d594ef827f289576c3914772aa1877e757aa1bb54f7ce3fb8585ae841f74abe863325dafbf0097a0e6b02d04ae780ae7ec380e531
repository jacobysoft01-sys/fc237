ram: router.urlStateParam,\n      }}\n    >\n      {props.canActivate ? <RouteGuard canActivate={props.canActivate}>{props.children}</RouteGuard> : props.children}\n    </RouteContext.Provider>\n  );\n}\n"],"mappings":";;;;;;;;;;AA4BA,MAAM,cAAc,EAAE,aAAa,eAA6E;CAC9G,MAAM,EAAE,wBAAwB,uBAAuB;CACvD,MAAM,QAAQ,SAAS;CAEvB,MAAM,gBAAgB;EACpB,IAAI,CAAC,YAAY,KAAK,GACpB,AAAK,oBAAoB;CAE7B,CAAC;CACD,IAAI,YAAY,KAAK,GACnB,OAAO,kCAAG,SAAW;CAEvB,OAAO;AACT;AAEA,SAAgB,MAAM,OAAuC;CAC3D,MAAM,SAAS,UAAU;CAEzB,IAAI,CAAC,MAAM,UACT,OAAO;CAGT,IAAI,CAAC,MAAM,SAAS,CAAC,MAAM,MACzB,OAAO,4CAAG,MAAM,SAAW;CAG7B,IAAI,CAAC,OAAO,QAAQ,MAAM,MAAM,MAAM,KAAK,GACzC,OAAO;CAGT,MAAM,CAAC,WAAW,YAAY,SAAS,OAAO,WAAW,OAAO,UAAU,MAAM,MAAM,MAAM,KAAK;CAEjG,MAAM,WAAW,IAAY,EAAE,iBAAqD,CAAC,MAAM;EACzF,MAAM,MAAM,IAAI,IAAI,IAAI,OAAO,SAAS,SAAS,WAAW,GAAG;EAC/D,IAAI,cACF,IAAI,SAAS,aAAa,SAAS;EAErC,IAAI,WAAW,kBAAkB,IAAI,QAAQ;EAC7C,OAAO;CACT;CAEA,MAAM,mBAAmB,MAAe,UAAoB;EAC1D,MAAM,CAAC,cAAc,eAAe,SAAS,WAAW,UAAU,MAAM,KAAK;EAC7E,MAAM,cAAc,kBAAkB,OAAO,WAAW;EACxD,MAAM,cACH,QAAQ,MAAM,cAAc,QAAQ,CAAC,CAAC,WAAW,KACjD,SAAS,MAAM,YAAY,CAAC,CAAC,WAAW,KACxC,SAAS,MAAM,WAAW,CAAC,CAAC,WAAW,KACxC;EACF,IAAI,gBAAgB,OAClB,OAAO,YAAY;OAEnB,OAAO;CAEX;CAEA,MAAM,YAAY,OAAO,aAAa,MAAM,MAAM,MAAM,KAAK,KAAK,CAAC;CACnE,MAAM,aAAqC,CAAC;CAC5C,KAAK,MAAM,CAAC,KAAK,UAAU,OAAO,QAAQ,SAAS,GACjD,WAAW,OAAO;CAGpB,MAAM,iBACH,MAAM,YAGH,iBAAiB,OAAO,QAAQ,CAAC,CAAC,QAAQ,MAAM,OAAO,UAAU,EAAE,IACnE,OAAO,kBAAkB,OAAO;CAEtC,OACE,oBAAC,aAAa,UAAd;EACE,OAAO;GACL,UAAU,OAAO;GACjB,WAAW,OAAO;GACH;GACJ;GACD;GACV,aAAa,OAAO;GACpB,aAAa,OAAO;GACpB,aAAa,OAAO;GACpB,cAAc,OAAO;GACrB,cAAc;GACd,UAAU,MAAe,UAAoB;IAC3C,OAAO,gBAAgB,MAAM,KAAK,IAAI,OAAO;GAC/C;GACS;GACT,WAAW,IAAY,EAAE,iBAAiB,CAAC,MAAM;IAC/C,MAAM,QAAQ,QAAQ,IAAI,EAAE,aAAa,CAAC;IAC1C,OAAO,OAAO,aAAa,KAAK;GAClC;GACA,SAAS,OAAO;GAChB,QAAQ;GACR,eAAe,OAAO;EACxB;YAEC,MAAM,cAAc,oBAAC,YAAD;GAAY,aAAa,MAAM;aAAc,MAAM;EAAqB,KAAI,MAAM;CAClF;AAE3B"}