        context={context}\n          initialFocus={initialFocus}\n          order={order}\n        >\n          <>{children}</>\n        </FloatingFocusManager>\n      )}\n    </FloatingNode>\n  );\n};\n"],"mappings":";;;;;;AAyBA,MAAa,WAAW,UAAwB;CAC9C,MAAM,EACJ,SACA,cACA,uBAAuB,OACvB,QAAQ,CAAC,aAAa,SAAS,GAC/B,QACA,QACA,SAAS,MACT,MACA,aACE;CAEJ,MAAM,aAAa,cAAc;CACjC,MAAM,gBAAgB,QAAQ,aAAa,KAAK;CAEhD,IAAI,QACF,OACE,oBAAC,cAAD;EAAc,IAAI;YAChB,oBAAC,gBAAD;GAAgB,MAAM;aACnB,UACC,oBAAC,sBAAD;IACW;IACK;IACQ;IACf;cAEP,kCAAG,SAAW;GACM;EAEV;CACJ;CAIlB,OACE,oBAAC,cAAD;EAAc,IAAI;YACf,UACC,oBAAC,sBAAD;GACW;GACK;GACP;aAEP,kCAAG,SAAW;EACM;CAEZ;AAElB"}