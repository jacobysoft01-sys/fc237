        borderColor: t.colors.$borderAlpha100,\n        display: 'inline-flex',\n        marginInlineEnd: '1px',\n        cursor: 'pointer',\n        ':hover': {\n          backgroundColor: t.colors.$neutralAlpha100,\n        },\n        ':hover svg': {\n          color: t.colors.$danger500,\n        },\n        overflow: 'hidden',\n      })}\n    >\n      <Text\n        truncate\n        variant='buttonSmall'\n      >\n        {children}\n      </Text>\n      <Icon\n        elementDescriptor={descriptors.tagPillIcon}\n        size='md'\n        icon={Plus}\n        sx={t => ({ color: t.colors.$colorMutedForeground, transform: 'translateY(0px) rotate(45deg)' })}\n      />\n    </Flex>\n  );\n};\n"],"mappings":";;;;;;;;;;AAUA,MAAM,YAAY,QAAgB,IAAI,KAAK;AAW3C,MAAa,YAAY,UAAyB;CAChD,MAAM,EAAE,MAAM,iBAAiB;CAC/B,MAAM,EAAE,WAAW,oBAAoB,cAAc,CAAC,CAAC;CACvD,MAAM,EACJ,IACA,aACA,iBAAiB,MACjB,OAAO,WACP,UAAU,cACV,WAAW,eACX,iCAAiC,MACjC,GAAG,SACD;CACJ,MAAM,YAAY,mBAAmB;CACrC,MAAM,OAAO,UAAU,MAAM,GAAG,CAAC,CAAC,IAAI,QAAQ,CAAC,CAAC,OAAO,OAAO;CAC9D,MAAM,UAAU,IAAI,IAAI,IAAI;CAC5B,MAAM,iBAAiB,MAAM,OAAO,IAAI;CACxC,MAAM,WAAW,MAAM,OAAyB,IAAI;CACpD,MAAM,CAAC,OAAO,YAAY,MAAM,SAAS,EAAE;CAE3C,MAAM,QAAQ,YAAmB;EAC/B,aAAa,EAAE,QAAQ,EAAE,OAAO,QAAQ,KAAK,GAAG,EAAE,EAAE,CAAQ;EAC5D,WAAW;EACX,yBAAyB,EAAE;CAC7B;CAEA,MAAM,UAAU,QAAa;EAC3B,KAAK,KAAK,QAAO,MAAK,MAAM,GAAG,CAAC;CAClC;CAEA,MAAM,mBAAmB;EACvB,KAAK,KAAK,MAAM,GAAG,EAAE,CAAC;CACxB;CAEA,MAAM,UAAU,QAAqB;EAEnC,MAAM,WAAW,MAAM,QAAQ,GAAG,IAAI,CAAC,GAAG,GAAG,IAAI,CAAC,GAAG,EAAC,CACnD,IAAI,QAAQ,CAAC,CACb,OAAO,OAAO,CAAC,CACf,OAAO,QAAQ,CAAC,CAChB,QAAO,MAAK,CAAC,QAAQ,IAAI,CAAC,CAAC;EAE9B,IAAI,QAAQ,QAAQ;GAClB,KAAK,CAAC,GAAG,MAAM,GAAG,OAAO,CAAC;GAC1B,SAAS,EAAE;GACX,WAAW;EACb;CACF;CAEA,MAAM,mBAAmB;EACvB,SAAS,SAAS,MAAM;CAC1B;CAEA,MAAM,iBAA8D,MAAK;EACvE,MAAM,EAAE,QAAQ;EAChB,KAAK,QAAQ,OAAO,QAAQ,OAAO,QAAQ,YAAY,CAAC,CAAC,MAAM,QAAQ;GACrE,EAAE,eAAe;GACjB,OAAO,KAAK;EACd,OAAO,IAAI,QAAQ,eAAe,CAAC,MAAM,UAAU,CAAC,CAAC,KAAK,UAAU,eAAe,SAAS;GAC1F,EAAE,eAAe;GACjB,WAAW;EACb;EACA,eA