{"version":3,"file":"sanitizeDomProps.js","names":[],"sources":["../../../src/customizables/sanitizeDomProps.tsx"],"sourcesContent":["import React from 'react';\n\n/**\n * Removes any non-native attributes before the components gets committed to the DOM\n * simply by destructuring the unwanted props out of `props`\n */\nexport const sanitizeDomProps = <P extends React.FunctionComponent<any>>(Component: P): P => {\n  const component = React.forwardRef((props: any, ref) => {\n    const { elementId, elementDescriptor, localizationKey, getContainer, ...restProps } = props;\n    return (\n      <Component\n        {...restProps}\n        ref={ref}\n      />\n    );\n  });\n  return component as unknown as P;\n};\n"],"mappings":";;;;;;;;AAMA,MAAa,oBAA4D,cAAoB;CAU3F,OATkB,MAAM,YAAY,OAAY,QAAQ;EACtD,MAAM,EAAE,WAAW,mBAAmB,iBAAiB,cAAc,GAAG,cAAc;EACtF,OACE,oBAAC,WAAD;GACE,GAAI;GACC;EACN;CAEL,CACe;AACjB"}