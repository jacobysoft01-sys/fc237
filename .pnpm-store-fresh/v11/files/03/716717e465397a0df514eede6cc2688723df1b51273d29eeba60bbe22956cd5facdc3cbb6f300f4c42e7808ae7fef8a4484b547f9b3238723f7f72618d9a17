);\n  return (\n    <Flex\n      elementDescriptor={descriptors.formFieldRadioGroupItem}\n      align='start'\n    >\n      <RadioIndicator\n        id={randomId}\n        ref={ref}\n        value={props.value}\n      />\n\n      <RadioLabel\n        id={randomId}\n        label={props.label}\n        description={props.description}\n      />\n    </Flex>\n  );\n});\n"],"mappings":";;;;;;;AAMA,MAAM,iBAAiB,YAA6D,OAAO,QAAQ;CAEjG,MAAM,EAAE,OAAO,aAAa,GAAG,eAAe,mBAD5B,aACuD,CAAC;CAE1E,OACE,oBAAC,YAAD;EACO;EACL,GAAI;EACJ,mBAAmB,YAAY;EAC/B,IAAI,MAAM;EACV,WAAW;EACX,KAAI,OAAM;GACR,OAAO;GACP,WAAW,EAAE,MAAM;EACrB;EACA,OAAO,MAAM;EACb,SAAS,MAAM,UAAU;CAC1B;AAEL,CAAC;AAED,MAAa,cAAc,UAIrB;CACJ,OACE,qBAAC,WAAD;EACE,mBAAmB,YAAY;EAC/B,SAAS,MAAM;EACf,KAAI,OAAM;GACR,SAAS,GAAG,EAAE,MAAM,MAAM,GAAG,EAAE,MAAM;GACrC,SAAS;GACT,eAAe;EACjB;YAPF,CASE,oBAAC,MAAD;GACE,mBAAmB,YAAY;GAC/B,SAAQ;GACR,iBAAiB,MAAM;EACxB,IAEA,MAAM,eACL,oBAAC,MAAD;GACE,mBAAmB,YAAY;GAC/B,aAAY;GACZ,iBAAiB,MAAM;EACxB,EAEM;;AAEf;AAEA,MAAa,YAAY,YAOtB,OAAO,QAAQ;CAChB,MAAM,WAAW,MAAM;CACvB,OACE,qBAAC,MAAD;EACE,mBAAmB,YAAY;EAC/B,OAAM;YAFR,CAIE,oBAAC,gBAAD;GACE,IAAI;GACC;GACL,OAAO,MAAM;EACd,IAED,oBAAC,YAAD;GACE,IAAI;GACJ,OAAO,MAAM;GACb,aAAa,MAAM;EACpB,EACG;;AAEV,CAAC"}