      },\n          childrenSx,\n        ]}\n      >\n        <Text\n          elementDescriptor={textElementDescriptor}\n          elementId={textElementId}\n          as='span'\n          truncate\n          variant={textVariant}\n          localizationKey={textLocalizationKey}\n        >\n          {children}\n        </Text>\n        {badge}\n      </Flex>\n      {rightIcon && (\n        <Icon\n          elementDescriptor={arrowElementDescriptor}\n          elementId={arrowElementId}\n          icon={rightIcon}\n          sx={[\n            theme => ({\n              transition: 'all 100ms ease',\n              minWidth: theme.sizes.$4,\n              minHeight: theme.sizes.$4,\n              width: '1em',\n              height: '1em',\n              opacity: `var(--arrow-opacity)`,\n              transform: `var(--arrow-transform)`,\n              '[dir=\"rtl\"] &': {\n                transform: `var(--arrow-transform) scaleX(-1)`,\n              },\n            }),\n            rightIconSx,\n          ]}\n        />\n      )}\n    </SimpleButton>\n  );\n});\n"],"mappings":";;;;;;AA2BA,MAAa,mBAAmB,MAAM,YAAsD,OAAO,QAAQ;CACzG,MAAM,EACJ,YAAYA,eACZ,aACA,UACA,YACA,mBACA,2BACA,WACA,UACA,uBACA,eACA,0BACA,kBACA,wBACA,gBACA,qBACA,YACA,OACA,cAAc,eACd,GAAG,SACD;CAEJ,MAAM,gBAAgB,eAAe,QAAQ;CAE7C,OACE,qBAAC,cAAD;EACE,SAAQ;EACR;EACW;EACX,GAAI;EACC;EACL,KAAI,UAAS,CACX;GACE,KAAK,MAAM,MAAM;GACjB,UAAU;GACV,gBAAgB;GAChB,aAAa,MAAM,OAAO;GAC1B,YAAY;GACZ,SAAS,GAAG,MAAM,MAAM,KAAK,GAAG,MAAM,MAAM,GAAG,GAAG,MAAM,MAAM,KAAK,GAAG,MAAM,MAAM;GAClF,mBAAmB;GACnB,qBAAqB,eAAe,MAAM,MAAM,GAAG;GACnD,oBAAoB;IAClB,mBAAmB;IACnB,qBAAqB;GACvB;GACA,mBAAiB,EACf,qBAAqB,cAAc,MAAM,MAAM,GAAG,GACpD;GACA,gDAA4C,EAC1C,qBAAqB,kBACvB;EACF,GACA,MAAM,EACR;YA5BF;IA8BI,aAAa,aACb,oBAAC,MAAD;IACE,IAAG;IACH,KAAI,WAAU;KAAE,OAAO,MAAM,MAAM;KAAI,QAAQ,MAAM,MAAM;KAAI,MAAM;KAAQ,YAAY;IAAS;cAEjG,YACC,oBAAC,SAAD;KACE,mBAAmB;KACnB,WAAW;KACX,MAAM;IACP,KACC,CAAC,iBAAiB,WACpB,oBAAC,MAAD;KACE,mBAAmB;KACnB,WAAW;KACX,MAAM;KACN,IAAI,EACF,WA