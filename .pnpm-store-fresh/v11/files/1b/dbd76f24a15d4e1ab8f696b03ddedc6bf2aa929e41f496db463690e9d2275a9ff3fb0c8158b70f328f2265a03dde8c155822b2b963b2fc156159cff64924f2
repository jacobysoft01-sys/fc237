{"version":3,"file":"PaymentAttemptsList.js","names":[],"sources":["../../../../src/components/PaymentAttempts/PaymentAttemptsList.tsx"],"sourcesContent":["import type { BillingPaymentResource } from '@clerk/shared/types';\n\nimport { DataTable, DataTableRow } from '@/ui/elements/DataTable';\nimport { formatDate } from '@/ui/utils/formatDate';\nimport { truncateWithEndVisible } from '@/ui/utils/truncateTextWithEndVisible';\n\nimport { usePaymentAttempts, useSubscriberTypeLocalizationRoot } from '../../contexts';\nimport { Badge, localizationKeys, Td, Text } from '../../customizables';\nimport { useRouter } from '../../router';\n\n/* -------------------------------------------------------------------------------------------------\n * PaymentAttemptsList\n * -----------------------------------------------------------------------------------------------*/\n\nexport const PaymentAttemptsList = () => {\n  const { data: paymentAttempts, isLoading, count } = usePaymentAttempts();\n  const localizationRoot = useSubscriberTypeLocalizationRoot();\n\n  return (\n    <DataTable\n      page={1}\n      onPageChange={_ => {}}\n      itemCount={count}\n      pageCount={1}\n      itemsPerPage={10}\n      isLoading={isLoading}\n      emptyStateLocalizationKey={localizationKeys(`${localizationRoot}.billingPage.paymentHistorySection.empty`)}\n      headers={[\n        { key: localizationKeys(`${localizationRoot}.billingPage.paymentHistorySection.tableHeader__date`) },\n        { key: localizationKeys(`${localizationRoot}.billingPage.paymentHistorySection.tableHeader__amount`) },\n        { key: localizationKeys(`${localizationRoot}.billingPage.paymentHistorySection.tableHeader__status`) },\n      ]}\n      rows={paymentAttempts.map(i => (\n        <PaymentAttemptsListRow\n          key={i.id}\n          paymentAttempt={i}\n        />\n      ))}\n    />\n  );\n};\n\nconst PaymentAttemptsListRow = ({ paymentAttempt }: { paymentAttempt: BillingPaymentResource }) => {\n  const { id, amount, failedAt, paidAt, updatedAt, status } = paymentAttempt;\n  const { navigate } = useRouter();\n  const handleClick = () => {\n    void navigate(`payment-attempt/${id}`);\n  };\n  return (\n    <DataTableRow onClick={handleClick}>\n      <Td\n        sx={{\n          cursor: 'pointer',\n        }}\n      >\n        <Text variant='subtitle'>{formatDate(paidAt || failedAt || updatedAt, 'long')}</Text>\n        <Text\n          colorScheme='secondary'\n          variant='caption'\n          truncate\n          sx={t => ({ marginTop: t.space.$0x5 })}\n        >\n          {truncateWithEndVisible(id)}\n        </Text>\n      </Td>\n      <Td\n        sx={{\n          cursor: 'pointer',\n        }}\n      >\n        <Text>\n          {amount.currencySymbol}\n          {amount.amountFormatted}\n        </Text>\n      </Td>\n      <Td>\n        <Badge\n          colorScheme={status === 'paid' ? 'success' : status === 'failed' ? 'danger' : 'primary'}\n          sx={{ textTransform: 'capitalize' }}\n        >\n          {status}\n        </Badge>\n      </Td>\n    </DataTableRow>\n  );\n};\n"],"mappings":";;;;;;;;;;;AAcA,MAAa,4BAA4B;CACvC,MAAM,EAAE,MAAM,iBAAiB,WAAW,UAAU,mBAAmB;CACvE,MAAM,mBAAmB,kCAAkC;CAE3D,OACE,oBAAC,WAAD;EACE,MAAM;EACN,eAAc,MAAK,CAAC;EACpB,WAAW;EACX,WAAW;EACX,cAAc;EACH;EACX,2BAA2B,iBAAiB,GAAG,iBAAiB,yCAAyC;EACzG,SAAS;GACP,EAAE,KAAK,iBAAiB,GAAG,iBAAiB,qDAAqD,EAAE;GACnG,EAAE,KAAK,iBAAiB,GAAG,iBAAiB,uDAAuD,EAAE;GACrG,EAAE,KAAK,iBAAiB,GAAG,iBAAiB,uDAAuD,EAAE;EACvG;EACA,MAAM,gBAAgB,KAAI,MACxB,oBAAC,wBAAD,EAEE,gBAAgB,EACjB,GAFM,EAAE,EAER,CACF;CACF;AAEL;AAEA,MAAM,0BAA0B,EAAE,qBAAiE;CACjG,MAAM,EAAE,IAAI,QAAQ,UAAU,QAAQ,WAAW,WAAW;CAC5D,MAAM,EAAE,aAAa,UAAU;CAC/B,MAAM,oBAAoB;EACxB,AAAK,SAAS,mBAAmB,IAAI;CACvC;CACA,OACE,qBAAC,cAAD;EAAc,SAAS;YAAvB;GACE,qBAAC,IAAD;IACE,IAAI,EACF,QAAQ,UACV;cAHF,CAKE,oBAAC,MAAD;KAAM,SAAQ;eAAY,WAAW,UAAU,YAAY,WAAW,MAAM;IAAQ,IACpF,oBAAC,MAAD;KACE,aAAY;KACZ,SAAQ;KACR;KACA,KAAI,OAAM,EAAE,WAAW,EAAE,MAAM,KAAK;eAEnC,uBAAuB,EAAE;IACtB,EACJ;;GACJ,oBAA