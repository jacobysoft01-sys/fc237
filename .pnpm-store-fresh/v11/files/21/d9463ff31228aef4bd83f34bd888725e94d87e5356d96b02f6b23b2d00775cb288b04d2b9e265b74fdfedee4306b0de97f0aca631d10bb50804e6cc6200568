{"version":3,"file":"CardAction.js","names":[],"sources":["../../../../src/elements/Card/CardAction.tsx"],"sourcesContent":["import type { CardActionId } from '@clerk/shared/types';\nimport React from 'react';\n\nimport { descriptors, Flex, Text } from '../../customizables';\nimport type { PropsOfComponent } from '../../styledSystem';\nimport { RouterLink } from '../RouterLink';\n\ntype CardActionProps = Omit<PropsOfComponent<typeof Flex>, 'elementId'> & {\n  elementId?: CardActionId;\n};\nexport const CardAction = (props: CardActionProps): JSX.Element => {\n  const { elementId, sx, ...rest } = props;\n  return (\n    <Flex\n      elementDescriptor={descriptors.footerAction}\n      elementId={descriptors.footerAction.setId(elementId)}\n      {...rest}\n      gap={1}\n      sx={[\n        t => ({\n          margin: `${t.space.$none} auto`,\n        }),\n        sx,\n      ]}\n    />\n  );\n};\n\nexport const CardActionText = (props: React.PropsWithChildren<any>): JSX.Element => {\n  return (\n    <Text\n      elementDescriptor={descriptors.footerActionText}\n      {...props}\n      as='span'\n      variant='body'\n      colorScheme='secondary'\n    />\n  );\n};\n\nexport const CardActionLink = (props: PropsOfComponent<typeof RouterLink>): JSX.Element => {\n  return (\n    <RouterLink\n      elementDescriptor={descriptors.footerActionLink}\n      {...props}\n      colorScheme='primary'\n      variant='buttonLarge'\n    />\n  );\n};\n"],"mappings":";;;;;;;AAUA,MAAa,cAAc,UAAwC;CACjE,MAAM,EAAE,WAAW,IAAI,GAAG,SAAS;CACnC,OACE,oBAAC,MAAD;EACE,mBAAmB,YAAY;EAC/B,WAAW,YAAY,aAAa,MAAM,SAAS;EACnD,GAAI;EACJ,KAAK;EACL,IAAI,EACF,OAAM,EACJ,QAAQ,GAAG,EAAE,MAAM,MAAM,OAC3B,IACA,EACF;CACD;AAEL;AAEA,MAAa,kBAAkB,UAAqD;CAClF,OACE,oBAAC,MAAD;EACE,mBAAmB,YAAY;EAC/B,GAAI;EACJ,IAAG;EACH,SAAQ;EACR,aAAY;CACb;AAEL;AAEA,MAAa,kBAAkB,UAA4D;CACzF,OACE,oBAAC,YAAD;EACE,mBAAmB,YAAY;EAC/B,GAAI;EACJ,aAAY;EACZ,SAAQ;CACT;AAEL"}