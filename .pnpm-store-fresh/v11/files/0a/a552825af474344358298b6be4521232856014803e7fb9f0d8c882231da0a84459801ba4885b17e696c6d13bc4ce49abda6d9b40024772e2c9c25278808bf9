{"version":3,"file":"FormErrorText.js","names":["ExclamationCircle"],"sources":["../../../src/primitives/FormErrorText.tsx"],"sourcesContent":["import React, { forwardRef } from 'react';\n\nimport { Icon } from '../customizables';\nimport { ExclamationCircle } from '../icons';\nimport type { StyleVariants } from '../styledSystem';\nimport { animations, createVariants } from '../styledSystem';\nimport { useFormField } from './hooks/useFormField';\nimport { Text } from './Text';\n\nconst { applyVariants } = createVariants(theme => ({\n  base: {\n    marginTop: theme.sizes.$1x5,\n    animation: `${animations.textInSmall} ${theme.transitionDuration.$fast}`,\n    display: 'flex',\n    gap: theme.sizes.$1,\n    position: 'absolute',\n    top: '0',\n    textAlign: 'start',\n  },\n  variants: {},\n}));\n\ntype FormErrorTextProps = React.PropsWithChildren<StyleVariants<typeof applyVariants>>;\n\nexport const FormErrorText = forwardRef<HTMLElement, FormErrorTextProps>((props, ref) => {\n  const { hasError } = useFormField() || {};\n\n  if (!hasError && !props.children) {\n    return null;\n  }\n\n  const { children, ...rest } = props;\n\n  return (\n    <Text\n      ref={ref}\n      colorScheme='danger'\n      {...rest}\n      css={applyVariants(props)}\n    >\n      <Icon\n        colorScheme={'danger'}\n        icon={ExclamationCircle}\n      />\n      {children}\n    </Text>\n  );\n});\n"],"mappings":";;;;;;;;;;AASA,MAAM,EAAE,kBAAkB,gBAAe,WAAU;CACjD,MAAM;EACJ,WAAW,MAAM,MAAM;EACvB,WAAW,GAAG,WAAW,YAAY,GAAG,MAAM,mBAAmB;EACjE,SAAS;EACT,KAAK,MAAM,MAAM;EACjB,UAAU;EACV,KAAK;EACL,WAAW;CACb;CACA,UAAU,CAAC;AACb,EAAE;AAIF,MAAa,gBAAgB,YAA6C,OAAO,QAAQ;CACvF,MAAM,EAAE,aAAa,aAAa,KAAK,CAAC;CAExC,IAAI,CAAC,YAAY,CAAC,MAAM,UACtB,OAAO;CAGT,MAAM,EAAE,UAAU,GAAG,SAAS;CAE9B,OACE,qBAAC,MAAD;EACO;EACL,aAAY;EACZ,GAAI;EACJ,KAAK,cAAc,KAAK;YAJ1B,CAME,oBAAC,MAAD;GACE,aAAa;GACb,MAAMA;EACP,IACA,QACG;;AAEV,CAAC"}